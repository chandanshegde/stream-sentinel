%%{init: {"theme": "default"}}%%
flowchart TD
  subgraph Producers["🟦 Producers"]
    A["REST & gRPC Ingest API\nSpring Boot 3.x\nJSON & Protobuf\nAsync publish · 202 Accepted"]
    B["Internal Producers\nPulsar SDK / gRPC Clients"]
  end

  subgraph PulsarBus["🟧 Apache Pulsar (Message Bus)"]
    RAW["persistent://{tenant}/ingestion/raw-events\n16 partitions · 24h retention\nSchema Registry enforced"]
    SAN["persistent://{tenant}/ingestion/sanitized-events\n16 partitions · 7d retention"]
    AUD["persistent://{tenant}/ingestion/audit-events\n4 partitions · 7d → S3 tiered"]
    DLQ["persistent://{tenant}/ingestion/dlq\n4 partitions · 30d retention"]
  end

  subgraph FlinkJob["🟩 Flink Streaming Job (Java)"]
    direction TB
    F1["① Parse & Validate\nJSON/Protobuf · Side-output DLQ\nparallelism=16"]
    F2["② Redaction (Regex + WASM)\nEmbedded WASM UDFs per tenant\nStateless · parallelism=16"]
    F3["③ Async NER Call\nArrow Flight (Zero-copy RPC)\nBatch=64 · timeout=5s · parallelism=8"]
    F4["④ Abuse Scoring\nEmbedded DJL + ONNX\nDistilBERT natively in JVM · parallelism=8"]
    F5["⑤ Escalation Decision\nKeyedProcessFunction on tenantId\nBroadcastState for tenant policy"]
    F6["⑥ Async LLM Adapter\nAsyncDataStream.orderedWait\nmaxInFlight=20 · circuit-breaker · parallelism=4"]
    F7["⑦ Finalize Redaction\nHMAC-SHA256 pseudonymization\nKMS-managed salt per tenant"]
    F8["⑧ Sinks\nTwoPhaseCommitSink\nPulsar + Postgres + Iceberg"]

    F1 -->|valid| F2
    F1 -->|invalid| DLQ
    F2 --> F3
    F3 --> F4
    F4 --> F5
    F5 -->|"abuse_score > threshold\n OR ner ambiguous"| F6
    F5 -->|clear path| F7
    F6 --> F7
    F7 --> F8
  end

  subgraph NERService["🟪 NER Microservice"]
    NER["NER Worker \nPython + spaCy / Rust\nArrow Flight Server\nSidecar pod"]
  end

  subgraph LLMAdapterSvc["🟥 LLM Adapter"]
    LLM["LlmAdapter interface\nOpenAI / Anthropic / Ollama\nInput: redacted snippet + features ONLY\nNo raw PII ever sent"]
  end

  subgraph Storage["🗄️ Storage Layer"]
    PG[("Postgres (pgvector)\nevents_sanitized\naudit_records (append-only)\nescalations")]
    ICE[("Apache Iceberg\nParquet Files on S3\nREST/Nessie Catalog")]
    VEC[("Vector Store\nEmbeddings for RAG\nSemantic incident search")]
  end

  subgraph Downstream["📤 Downstream Consumers"]
    ANA["Analytics / BI\nAthena / Flink batch over Iceberg"]
    CHAT["AI Chatbot\nRAG over audit + sanitized events\npgvector similarity search"]
    MOD["Human Review UI\nEscalations queue\nPATCH /escalations/{id}"]
  end

  subgraph Observability["📊 Observability"]
    OTEL["OpenTelemetry Collector\nW3C TraceContext propagation"]
    PROM["Prometheus\nFlink + JVM + custom metrics"]
    GRAF["Grafana\nThroughput · Escalation · LLM cost"]
  end

  A --> RAW
  B --> RAW
  RAW --> F1
  F3 <-->|"Arrow Flight RPC\nin-memory Arrow IPC"| NER
  F6 <-->|"POST /llm/classify\nredacted context only"| LLM
  F8 --> SAN
  F8 --> AUD
  F8 --> PG
  F7 -->|embed sanitized payload| VEC
  SAN --> ANA
  SAN --> CHAT
  AUD --> MOD
  PG --> CHAT
  PG --> MOD

  FlinkJob -->|metrics| PROM
  NER -->|traces| OTEL
  LLMAdapterSvc -->|traces| OTEL
  A -->|traces| OTEL
  OTEL --> PROM
  PROM --> GRAF
